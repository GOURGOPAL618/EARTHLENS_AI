# ============================================================
#  EARTHLENS AI — Environment Variables Template
#  Copy this file → rename to .env → fill your values
#  NEVER commit your actual .env file (it's in .gitignore)
# ============================================================

# ------------------------------------------------------------
#  GOOGLE EARTH ENGINE
# ------------------------------------------------------------
GEE_PROJECT_ID=your-gee-project-id

# ------------------------------------------------------------
#  SENTINEL HUB
# ------------------------------------------------------------
SENTINEL_HUB_CLIENT_ID=your-sentinel-hub-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sentinel-hub-client-secret

# ------------------------------------------------------------
#  USGS M2M API (Landsat)
# ------------------------------------------------------------
USGS_USERNAME=your-usgs-username
USGS_TOKEN=your-usgs-api-token

# ------------------------------------------------------------
#  APP CONFIG
# ------------------------------------------------------------
LOG_LEVEL=INFO
EARTHLENS_MODE=synthetic        # synthetic | gee | sentinel | landsat
EARTHLENS_DATA_DIR=earthlens_data/raw_imagery
EARTHLENS_OUTPUT_DIR=earthlens_data/processed_insights