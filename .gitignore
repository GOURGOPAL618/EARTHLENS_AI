*.pkl
*.joblib
*.h5
*.model

# GeoTIFF outputs
*.tif
*.tiff
*.geotiff

# Exported maps and charts
*.html
exports/
outputs/

# Temporary analysis files
temp/
tmp/
scratch/
*.tmp


# ------------------------------------------------------------
#  SECRETS & CREDENTIALS — NEVER COMMIT THESE
# ------------------------------------------------------------

# Environment variables
.env
.env.*
*.env
!.env.example

# Google Earth Engine credentials
credentials.json
gee_credentials.json
service_account_key.json
*_serviceaccount.json
earthengine_token.json
~/.config/earthengine/

# Sentinel Hub / USGS API keys
sentinel_config.py
api_keys.py
secrets.py
config_private.py
*_secret*
*_private*

# Any key or token file
*.key
*.pem
*.token
*.secret


